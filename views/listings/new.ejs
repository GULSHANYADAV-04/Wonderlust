<% layout("/layouts/boilerplate") %>
<br><br>
<div class="row">
  <div class="col-8 offset-2">
    <h3>Create a New Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
      <div class="mb-3">
        <label for ="title" class ="form-lable">Title</label>
      <input name="listing[title]" placeholder="enter title" type="text" class ="form-control" required />
      <div class="invalid-feedback">title should be valid</div>
      </div>

      <div class="mb-3">
    <label for="category" class="form-label">Category</label>

    <select
        class="form-select"
        id="category"
        name="listing[category]"
        required
    >
        <option value="">Select Category</option>

        <option value="Trending">Trending</option>
        <option value="Rooms">Rooms</option>
        <option value="Iconic City">Iconic City</option>
        <option value="Mountains">Mountains</option>
        <option value="Castles">Castles</option>
        <option value="Amazing Pools">Amazing Pools</option>
        <option value="Camping">Camping</option>
        <option value="Farms">Farms</option>
        <option value="Arctic">Arctic</option>
        <option value="Dome">Dome</option>
        <option value="Boats">Boats</option>
    </select>

    <div class="invalid-feedback">
        Please select a category.
    </div>
</div>

      <div class="mb-3">
         <label for ="description" class ="form-lable">Discription</label>
        <textarea
        name="listing[description]"
        class ="form-control" required
      ></textarea>
      <div class="invalid-feedback">please enter the sort discription</div>
      </div>

       <div class="mb-3">
        <label for ="image" class ="form-lable">upload Listng image</label>
        <input
        name="listing[image][url]"
        type="file"
         class ="form-control" required
      />
      </div>
      
      <div class="row">
      <div class="mb-3 col-md-4">
        <label for ="price" class ="Enter Price">price</label>
        <input name="listing[price]" placeholder="enter price" type="number"  class ="form-control" required/>
        <div class="invalid-feedback">Enter a valid number</div>
      </div>
      
      <div class="mb-3 col-md-8">
        <label for ="country" class ="Enter Country">Country</label>
       <input name="listing[country]" placeholder="enter country" type="text"  class ="form-control" required/>
       <div class="invalid-feedback">please enter the country </div>
      </div>
      </div>
      
      <div class="mb-3">
        <label for ="location" class ="Enter Location">location</label>
      <input
        name="listing[location]"
        placeholder="enter location"
        type="text"
         class ="form-control" required
      />
      <div class="invalid-feedback">please enter the location</div>
      </div>

      
     
      <br /><br />
      <button class ="btn btn-dark add-btn">Add</button>
    </form>
  </div>
</div>
<br>
